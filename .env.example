# ─── Frontend (Vite) — safe to expose, gated by RLS ────────────────────────
# Copy to web/.env.local and fill in from `supabase status` (local) or your
# Supabase project settings (cloud). Only the ANON key is ever shipped to the
# browser. NEVER put the service-role key in a VITE_* variable.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key

# ─── Seed import (server-side only, scripts/import_seed.ts) ────────────────
# The service-role key bypasses RLS. Used ONLY by the one-time seed import
# script, never bundled into the frontend. Keep this out of web/.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
