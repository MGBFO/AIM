{
  "name": "aim",
  "version": "0.1.0",
  "private": true,
  "description": "Analysis in Motion — Biltmore Family Office investment-analyst workflow app (Vite + React + Supabase)",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "npm --workspace web run dev",
    "build": "npm --workspace web run build",
    "typecheck": "npm --workspace web run typecheck",
    "lint": "npm --workspace web run lint",
    "test": "npm --workspace web run test",
    "test:integration": "npm --workspace web run test:integration",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "db:start": "npx --yes supabase start",
    "db:stop": "npx --yes supabase stop",
    "db:reset": "npx --yes supabase db reset",
    "seed:build": "python3 scripts/build_seed.py",
    "seed:import": "npm --workspace web run seed:import"
  }
}
